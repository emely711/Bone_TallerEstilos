<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" prefHeight="394.0" prefWidth="536.0" spacing="20.0" styleClass="contenedor" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.tallerestilo.HelloController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <Label fx:id="welcomeText" />
   <HBox prefHeight="38.0" prefWidth="473.0" spacing="10.0">
      <children>
         <Label styleClass="lbl" text="Nombre:" />
         <TextField fx:id="txtNombre" alignment="TOP_LEFT" prefHeight="25.0" prefWidth="179.0" promptText="Ingrese su nombre" styleClass="texto" stylesheets="@styles.css" />
      </children>
   </HBox>
   <HBox prefHeight="100.0" prefWidth="200.0" spacing="25.0">
      <children>
         <Label styleClass="lbl1" text="Precio:" />
         <TextField fx:id="txtPrecio" promptText="Ingrese el precio" styleClass="texto" />
      </children>
   </HBox>
   <HBox alignment="CENTER" prefHeight="81.0" prefWidth="496.0" spacing="50.0">
      <children>
          <Button onAction="#capturar" styleClass="boton" stylesheets="@styles.css" text="Capturar" />
         <Button mnemonicParsing="false" onAction="#limpiar" styleClass="boton1" text="Limpiar" />
         <Button mnemonicParsing="false" onAction="#salir" styleClass="boton2" text="Salir" />
      </children>
   </HBox>
   <HBox alignment="TOP_CENTER" prefHeight="100.0" prefWidth="200.0">
      <children>
         <Label alignment="TOP_CENTER" />
      </children>
   </HBox>
</VBox>
